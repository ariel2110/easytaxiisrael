# Copy this file to .env and fill in all values before running the application.
# NEVER commit .env to version control.

# ── Application ──────────────────────────────────────────────
APP_ENV=production
DEBUG=False
APP_TITLE=RideOS Platform API
APP_VERSION=0.1.0

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/rideos

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ─────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=15
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=https://yourdomain.com,https://driver.yourdomain.com

# ── Admin ────────────────────────────────────────────────────
ADMIN_USERNAME=
ADMIN_PASSWORD=

# ── Fare ─────────────────────────────────────────────────────
FARE_BASE=2.50
FARE_PER_KM=1.20
PLATFORM_FEE_PCT=15.0
TAX_PCT=10.0

# ── WhatsApp (Evolution API) ──────────────────────────────────
EVOLUTION_URL=http://evolution-api:8080
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=easytaxi
WHATSAPP_PLATFORM_PHONE=

# ── Persona KYC ───────────────────────────────────────────────
PERSONA_API_KEY=
PERSONA_WEBHOOK_SECRET=
PERSONA_TEMPLATE_ID=          # Template 1: GovID (ת"ז) + Driver License + Selfie
PERSONA_VEHICLE_TEMPLATE_ID=  # Template 2: vehicle docs (ביטוח + טסט + רישוי)
PERSONA_TAXI_LICENSE_TEMPLATE_ID=  # Template 3: רישיון נהיגה לרכב שכור (licensed_taxi only)
PERSONA_API_VERSION=2025-12-08

# ── LLM API Keys ─────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
GOOGLE_AI_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
SERPER_API_KEY=
GOOGLE_MAPS_API_KEY=
