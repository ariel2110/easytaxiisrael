# Application
APP_ENV=development
DEBUG=false

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rideos
POSTGRES_USER=rideos
POSTGRES_PASSWORD=rideos_secret
POSTGRES_DB=rideos

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=redis_secret

# JWT (use a long random secret in production)
JWT_SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Encryption (exactly 32 characters)
ENCRYPTION_KEY=change-me-32-bytes-encryption-key

# CORS (comma-separated, production only)
CORS_ORIGINS=https://easytaxiisrael.com,https://www.easytaxiisrael.com,https://driver.easytaxiisrael.com

# Fare (currency units)
FARE_BASE=2.50
FARE_PER_KM=1.20
PLATFORM_FEE_PCT=15.0
TAX_PCT=10.0


# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=change-me-grafana
